# =============================================================================
# InsightX API — Environment Variables
# =============================================================================
# USAGE:
#   Copy this file to .env and fill in the values:
#     cp .env.example .env
#
# NEVER commit .env to version control.
# In production, inject these via your secrets manager (AWS Secrets Manager,
# Azure Key Vault, etc.) — NOT via files in the repository.
# =============================================================================


# --- InsightX Metadata Database ---
# This is the internal PostgreSQL database that STORES datasource registrations.
# It is NOT the same as the datasources you register through the UI.
#
# Format: postgresql+asyncpg://user:password@host:port/database_name
#
# For production:
#   DATABASE_URL=postgresql+asyncpg://insightx:your_password@localhost:5432/insightx_meta
#
# For development (SQLite — no PostgreSQL required, tables are auto-created):
#   DATABASE_URL=sqlite+aiosqlite:///./insightx_dev.db
DATABASE_URL=postgresql+asyncpg://insightx_app:Era%401234@10.11.200.99:5432/insightx_meta

# --- AES-256-GCM Credential Encryption Key ---
# Used to encrypt all target datasource credentials before storing in the DB.
# The credentials entered by users through the UI are NEVER stored in plaintext.
#
# GENERATE A KEY:
#   python -c "import secrets; print(secrets.token_hex(32))"
#
# Requirements: exactly 64 hex characters (= 32 bytes = 256 bits)
# NEVER reuse this key across environments (dev/staging/prod should each have unique keys).
CREDENTIAL_ENCRYPTION_KEY=45131be8def3b66498c97cbdc3777f9b3c1f7d5b51d95ea66b0d8cc15b5f17e3


# --- Secure File Storage ---
# Directory where TLS certificates, Oracle Wallets, and Kerberos keytabs are stored.
# Must be:
#   - Outside the webroot (not accessible via HTTP)
#   - Writable by the Python process
#   - Persistent (in Docker: mount as a named volume, NOT ephemeral container storage)
SECURE_FILES_DIR=./secure-uploads


# --- Upload Limits ---
# Maximum allowed file size for cert/wallet/keytab uploads (in megabytes)
MAX_UPLOAD_SIZE_MB=5


KEYCLOAK_URL=http://10.11.200.109:8083
KEYCLOAK_REALM=InsigthX
KEYCLOAK_CLIENT_ID=InsightX
KEYCLOAK_CLIENT_SECRET=CJvRzoxwlqKKNckd6Q7c3pzvoyHcbW5v

# --- BFF OAuth redirect & frontend origin ---
# REDIRECT_URI must be registered in Keycloak: Clients → InsightX → Valid Redirect URIs
# FRONTEND_URL is also used for CORS — add the same value to Keycloak's Web Origins list
REDIRECT_URI=http://localhost:8091/api/auth/callback
FRONTEND_URL=http://localhost:5500


# --- Token introspection cache TTL ---
# Seconds a valid introspection result is reused before calling Keycloak again.
# Max 30 (per requirement). Lower values reduce the window for stale token reuse.
INTROSPECT_CACHE_TTL_SECONDS=30

#KEYCLOAK_VERIFY_SSL=false


# --- M4 Delta Lakehouse (Spark) — local machine configuration ---
# These describe THIS backend machine, not the remote Spark cluster (which is
# configured per-datasource in the UI: master host/port + HDFS namenode URI).
# Spark 3.5.x requires Java 8, 11, or 17 (NOT 21+).
#
# SPARK_JAVA_HOME: overrides JAVA_HOME before the first `import pyspark`.
#   SPARK_JAVA_HOME=C:\Program Files\Java\jdk-17\jdk-17.0.18
#
# SPARK_HOME_OVERRIDE: use a separately-downloaded Spark distribution's JARs
# instead of the ones bundled with the pip `pyspark` package (needed when the
# cluster runs a Scala version PyPI doesn't ship, e.g. Scala 2.13).
#   SPARK_HOME_OVERRIDE=E:\Spark Lab\spark-3.5.8-scala2.13
#
# SPARK_DELTA_PACKAGE: Maven coordinate for the Delta Lake Spark connector.
SPARK_JAVA_HOME=
SPARK_HOME_OVERRIDE=
SPARK_DELTA_PACKAGE=io.delta:delta-spark_2.13:3.2.1
SPARK_CONNECTION_TIMEOUT_SECONDS=90
